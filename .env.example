# Application
NODE_ENV="development"
APP_URL="http://localhost:3000"
DATABASE_URL="postgresql://beat:beat@localhost:5432/beat_the_market?schema=public"
# Generate with: openssl rand -base64 48
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Optional email delivery (SendByte). In development, magic links are logged
# to the server console when this is unset. Use sk_test_… for sandbox.
# Docs: https://docs.sendbyte.africa/
SENDBYTE_API_KEY=""
EMAIL_FROM="Beat the Market <noreply@yourdomain.com>"

# TxLINE network configuration
TXLINE_NETWORK="mainnet"
# Optional override. Defaults to the official host for TXLINE_NETWORK.
TXLINE_API_ORIGIN=""

# Server-only credentials created after TxLINE subscription activation.
# Never prefix these with NEXT_PUBLIC_.
TXLINE_GUEST_JWT=""
TXLINE_API_TOKEN=""

# Server-only Solana RPC used to build and simulate subscriptions.
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# Feed safety controls
TXLINE_REQUEST_TIMEOUT_MS="30000"
TXLINE_MAX_SNAPSHOT_AGE_MS="15000"
# Comma-separated competition IDs for live fixture catalogue sync (default WC).
TXLINE_COMPETITION_IDS="72"
